# ============================================
# ARISE Backend Environment Variables
# ============================================

# Server
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database (Supabase)
DATABASE_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-ap-south-1.pooler.supabase.com:5432/postgres"

# Supabase
SUPABASE_URL="https://[YOUR_PROJECT_REF].supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"
SUPABASE_ANON_KEY="your-supabase-anon-key"

# JWT
JWT_SECRET="arise-jwt-secret-change-in-production-make-it-long-and-random"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="arise-refresh-secret-change-in-production"
JWT_REFRESH_EXPIRES_IN="30d"

# AI Providers
AI_PROVIDER=groq

# Groq (https://console.groq.com)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_EMBEDDING_MODEL=llama-3.3-70b-versatile

# OpenAI (Optional - for switching providers)
OPENAI_API_KEY=

# Gemini (Optional)
GEMINI_API_KEY=

# Claude (Optional)
CLAUDE_API_KEY=

# Ollama (Optional - local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Single User Mode (default user created automatically)
SINGLE_USER_MODE=true
DEFAULT_USER_EMAIL=user@arise.local
DEFAULT_USER_NAME=User

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=50
